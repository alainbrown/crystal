{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["node", "react", "react-dom", "chrome"],
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["src", "remotion.config.ts"]
}
